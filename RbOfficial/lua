-- BUTTON CREATOR
local function createButton(text, posY, color)
	local Button = Instance.new("TextButton")
	Button.Parent = Main
	Button.Size = UDim2.new(0, 260, 0, 48)
	Button.Position = UDim2.new(0.5, -130, 0, posY)
	Button.BackgroundColor3 = color
	Button.Text = text
	Button.TextColor3 = Color3.new(1,1,1)
	Button.TextSize = 18
	Button.Font = Enum.Font.GothamBold
	Button.AutoButtonColor = false
	Button.BorderSizePixel = 0

	Instance.new("UICorner", Button).CornerRadius = UDim.new(0,14)

	local Stroke = Instance.new("UIStroke")
	Stroke.Parent = Button
	Stroke.Color = Color3.new(1,1,1)
	Stroke.Transparency = 0.8
	Stroke.Thickness = 1.5

	local Glow = Instance.new("UIGradient")
	Glow.Parent = Button
	Glow.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, color:Lerp(Color3.new(1,1,1),0.15)),
		ColorSequenceKeypoint.new(1, color)
	}
	Glow.Rotation = 90

	-- TAP / CLICK EFFECT
	local normalSize = Button.Size

	Button.MouseButton1Down:Connect(function()
		TweenService:Create(Button,TweenInfo.new(0.08),{
			Size = UDim2.new(0,250,0,44)
		}):Play()
	end)

	Button.MouseButton1Up:Connect(function()
		TweenService:Create(Button,TweenInfo.new(0.08),{
			Size = normalSize
		}):Play()
	end)

	Button.MouseEnter:Connect(function()
		TweenService:Create(Button,TweenInfo.new(0.15),{
			BackgroundColor3 = color:Lerp(Color3.new(1,1,1),0.12)
		}):Play()
	end)

	Button.MouseLeave:Connect(function()
		TweenService:Create(Button,TweenInfo.new(0.15),{
			BackgroundColor3 = color
		}):Play()
	end)

	return Button
end

