--// Button maker (closer to image)
local function createButton(name, text, y, color, strokeColor, textSize)
	local btn = Instance.new("TextButton")
	btn.Name = name
	btn.Parent = MainFrame
	btn.Size = UDim2.new(0, 218, 0, 42)
	btn.Position = UDim2.new(0.5, -109, 0, y)
	btn.BackgroundColor3 = color
	btn.BorderSizePixel = 0
	btn.Text = text
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.TextScaled = false
	btn.TextSize = textSize or 18
	btn.Font = Enum.Font.FredokaOne
	btn.AutoButtonColor = true
	btn.ZIndex = 7

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 12)
	corner.Parent = btn

	local stroke = Instance.new("UIStroke")
	stroke.Color = strokeColor
	stroke.Thickness = 1.5
	stroke.Parent = btn

	-- fake outlined text (like image)
	local outline = Instance.new("TextLabel")
	outline.Name = "Outline"
	outline.Parent = btn
	outline.BackgroundTransparency = 1
	outline.Size = UDim2.new(1, 0, 1, 0)
	outline.Position = UDim2.new(0, 2, 0, 2)
	outline.Text = text
	outline.TextColor3 = Color3.fromRGB(35, 35, 35)
	outline.TextTransparency = 0.2
	outline.TextScaled = false
	outline.TextSize = textSize or 18
	outline.Font = Enum.Font.FredokaOne
	outline.ZIndex = 7

	btn.ZIndex = 8
	return btn
end

