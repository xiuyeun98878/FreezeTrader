local function createToggle(text)
	local row = Instance.new("Frame")
	row.Parent = content
	row.Size = UDim2.new(1, 0, 0, 28)
	row.BackgroundColor3 = Color3.fromRGB(22, 22, 32)
	row.BorderSizePixel = 0

	local rowCorner = Instance.new("UICorner")
	rowCorner.CornerRadius = UDim.new(0, 8)
	rowCorner.Parent = row

	local leftIcon = Instance.new("Frame")
	leftIcon.Parent = row
	leftIcon.Size = UDim2.new(0, 16, 0, 16)
	leftIcon.Position = UDim2.new(0, 8, 0.5, -8)
	leftIcon.BackgroundColor3 = Color3.fromRGB(90, 60, 255)
	leftIcon.BorderSizePixel = 0

	local liCorner = Instance.new("UICorner")
	liCorner.CornerRadius = UDim.new(0, 4)
	liCorner.Parent = leftIcon

	local check = Instance.new("TextLabel")
	check.Parent = leftIcon
	check.Size = UDim2.new(1, 0, 1, 0)
	check.BackgroundTransparency = 1
	check.Text = "✓"
	check.TextColor3 = Color3.fromRGB(255,255,255)
	check.Font = Enum.Font.GothamBold
	check.TextSize = 10

	local label = Instance.new("TextLabel")
	label.Parent = row
	label.BackgroundTransparency = 1
	label.Position = UDim2.new(0, 30, 0, 0)
	label.Size = UDim2.new(1, -90, 1, 0)
	label.Text = text
	label.TextColor3 = Color3.fromRGB(240,240,255)
	label.Font = Enum.Font.GothamSemibold
	label.TextSize = 11
	label.TextXAlignment = Enum.TextXAlignment.Left

	local toggle = Instance.new("TextButton")
	toggle.Parent = row
	toggle.Size = UDim2.new(0, 34, 0, 16)
	toggle.Position = UDim2.new(1, -42, 0.5, -8)
	toggle.Text = ""
	toggle.BackgroundColor3 = Color3.fromRGB(50, 50, 65)
	toggle.BorderSizePixel = 0
	toggle.AutoButtonColor = false

	local tCorner = Instance.new("UICorner")
	tCorner.CornerRadius = UDim.new(1, 0)
	tCorner.Parent = toggle

	local knob = Instance.new("Frame")
	knob.Parent = toggle
	knob.Size = UDim2.new(0, 12, 0, 12)
	knob.Position = UDim2.new(0, 2, 0.5, -6)
	knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
	knob.BorderSizePixel = 0

	local kCorner = Instance.new("UICorner")
	kCorner.CornerRadius = UDim.new(1, 0)
	kCorner.Parent = knob

	local on = false

	local function refresh()
		if on then
			TweenService:Create(toggle, TweenInfo.new(0.15), {
				BackgroundColor3 = Color3.fromRGB(100, 65, 255)
			}):Play()
			TweenService:Create(knob, TweenInfo.new(0.15), {
				Position = UDim2.new(0, 20, 0.5, -6)
			}):Play()
		else
			TweenService:Create(toggle, TweenInfo.new(0.15), {
				BackgroundColor3 = Color3.fromRGB(50, 50, 65)
			}):Play()
			TweenService:Create(knob, TweenInfo.new(0.15), {
				Position = UDim2.new(0, 2, 0.5, -6)
			}):Play()
		end
		print(text .. " = " .. tostring(on))
	end

	toggle.MouseButton1Click:Connect(function()
		on = not on
		refresh()
	end)

	row.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			on = not on
			refresh()
		end
	end)

	refresh()
end

